[Unit]
Description=chitra dispatchd (JSON-queued tmux dispatch daemon)
Documentation=https://github.com/first-polyphony/chitra
After=network-online.target

[Service]
Type=simple
# Replace with the user/group this service should run as. Do not run as root.
User=chitra
Group=chitra
# systemd creates and owns this directory (mode 0750) for the unit's lifetime.
StateDirectory=chitra
# Comma-separated allowlist of remote hostnames dispatchd may target over ssh.
# Leave empty (the default) to allow local-host delivery only.
Environment=REMOTE_DISPATCH_HOSTS=
# Fill in the venv path where `pip install chitra` (or `pip install -e .`) was run.
ExecStart=/path/to/venv/bin/dispatchd --queue-dir /var/lib/chitra/queue --lock-dir /var/lib/chitra/locks --ledger-path /var/lib/chitra/ledger.jsonl --ledger-key-path /var/lib/chitra/ledger.key
Restart=always
RestartSec=10
TimeoutStopSec=45

[Install]
WantedBy=multi-user.target
