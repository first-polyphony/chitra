# Optional chitra policy. Point CHITRA_POLICY_CONFIG or dispatchd's
# --policy-config-path at a copy of this file. With no policy file, these
# shipped defaults are used unchanged.
completion_gate:
  # Case-insensitive literal phrases that dispute a completion claim.
  deferral_phrases:
    - "you'll need to"
    - "you will need to"
    - todo
    - "not implemented"
    - notimplemented
    - "out of scope"
    - "leaving for"
    - "leave for"
    - deferred
    - deferring
    - "close follow-up"
    - "close follow-ups"
    - "follow-up items"
    - "left as an exercise"
    - "in a future pr"
    - "future work"
  # Todo statuses treated as complete; all others are residue.
  complete_todo_statuses: [done]
  # Allowed values are deploy and live_verify. An empty list disables this check.
  required_evidence: [deploy, live_verify]
  # Optional path to a replacement taxonomy.json; null uses chitra's packaged taxonomy.
  taxonomy_path: null

dispatch:
  # Case-insensitive regexes blocked before a nudge is pasted.
  banned_attribution_patterns:
    - '\boperator\b'
    - '\bthe monitor\b'
    - '\bchitra (wants|says|needs|relays)\b'
  # Case-sensitive regexes that identify additional idle pane input rows.
  extra_idle_input_regexes: []

# Canonical decision documents for working-directory prefixes. The most-specific
# matching prefix wins; default is used when no configured prefix matches.
# guidance:
#   canonical_decisions:
#     /opt/polyphony/repo: /srv/onedrive-share/DocsHome/Projects_Dev/decisions.md
#     default: /srv/onedrive-share/DocsHome/decisions.md

# Usage snapshots are read and evaluated by chitra-usage. Uncomment this
# template to override the shipped defaults; chitra never pauses or resumes a lane.
# usage:
#   # Graceful-pause thresholds for Claude 5-hour/7-day windows (or Codex primary/secondary).
#   pause_5h_pct: 85.0
#   pause_7d_pct: 92.0
#   # Approaching thresholds: the monitor should avoid assigning new work.
#   warn_5h_pct: 70.0
#   warn_7d_pct: 85.0
#   # Dynamic running-lane cap; null disables deterministic throttle accounting.
#   max_running: null
#   # Whether the monitor may automatically re-arm timed holds after reset.
#   auto_resume: true
